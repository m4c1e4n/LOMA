rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Entity Validation Blueprints
    
    function isValidOpportunity(data) {
      return data.keys().hasAll(['title', 'companyName', 'type', 'location']) &&
             data.title is string && data.title.size() <= 200 &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.type in ['job', 'internship', 'training'] &&
             data.location is map &&
             data.location.lat is number &&
             data.location.lng is number;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             (data.get('favorites', []) is list) &&
             (data.get('completedResources', []) is list) &&
             (data.get('appliedJobs', []) is list);
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['userId', 'opportunityId', 'status', 'appliedAt']) &&
             data.userId == request.auth.uid &&
             isValidId(data.opportunityId) &&
             data.status in ['pending', 'reviewed', 'accepted', 'rejected'] &&
             data.appliedAt is timestamp;
    }

    // Collection Matches

    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if false; // System generated for now
    }

    match /learningResources/{resourceId} {
      allow read: if true;
      allow write: if false; // System generated
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && 
                      isValidUserProfile(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email;
    }

    match /applications/{applicationId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidApplication(incoming()) &&
                      exists(/databases/$(database)/documents/opportunities/$(incoming().opportunityId));
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) &&
                      isValidApplication(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().opportunityId == existing().opportunityId &&
                      incoming().appliedAt == existing().appliedAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
